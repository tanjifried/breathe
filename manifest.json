{
  "manifest_version": 3,
  "name": "Breathe",
  "description": "A Brave/Chrome extension for Facebook Messenger that gives couples a shared emotion regulation toolkit",
  "version": "1.0",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "host_permissions": [
    "*://www.messenger.com/*",
    "*://www.facebook.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://www.messenger.com/*", "*://www.facebook.com/*"],
      "css": ["styles.css"],
      "js": [
        "overlay.js",
        "calm.js",
        "status.js",
        "timeout.js",
        "reentry.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["styles.css"],
      "matches": ["*://www.messenger.com/*", "*://www.facebook.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
