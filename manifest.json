{
  "manifest_version": 3,
  "name": "Breathe",
  "description": "A Brave/Chrome extension for Facebook Messenger that gives couples a shared emotion regulation toolkit",
  "version": "1.0",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://www.messenger.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://www.messenger.com/*"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["styles.css"],
      "matches": ["*://www.messenger.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}